class Solution {
    public int getSecondLargest(int[] arr) {
      int first=Integer.MIN_VALUE;
      int second=Integer.MIN_VALUE;
      for(int num:arr){
         if(first<num){
         second=first;
         first=num;
      }
      
      else if(second<num&&first!=num){
          second=num;
      }
      
    }
    if (second == Integer.MIN_VALUE){
          return -1;
      }
    return second;
}
}
